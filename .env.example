# App configuration
PORT=3000

# Database configuration
POSTGRES_DB=mydatabase
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost/${POSTGRES_DB}

# Auth configuration
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=3600